# .env
# Backend-specific environment variables for RAG Q&A Demo (FastAPI)
# Copy this file to `.env` and fill in secrets for your environment.

# === LLM & Embeddings API Keys ===
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=
HF_TOKEN=

# === Vector Database Configuration ===
VECTOR_DB=faiss                # Options: faiss, pinecone
PINECONE_API_KEY=

# === Database Configuration ===
DATABASE_URL=postgresql+asyncpg://rag_user:rag_password@db:5432/rag_db

# === Embeddings Model ===
EMBEDDINGS_MODEL=text-embedding-ada-002

# === Backend Configuration ===
SECRET_KEY=your-backend-secret-key
PORT=8000

# === CORS ===
ALLOWED_ORIGINS=*

# === Prompt/Context Versioning ===
PROMPT_VERSION=v1

# === Evaluation ===
EVAL_SET_PATH=backend/data/eval_set.json

# === Optional: Other Settings ===
# LOG_LEVEL=info
# MAX_CONTEXT_DOCS=4
